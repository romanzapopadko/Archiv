{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "ConnectionStrings": {
      "Redis": "localhost:6379"
    },
    "Console": {
      "FormatterName": "Simple",
      "FormatterOptions": {
        "Pattern": "{DateTime} | {Level} | {Category} | {Message}",
        "TimestampFormat": "dd.MM.yyyy HH:mm:ss ",
        "UseUtcTimestamp": false
      }
    }
  },
  "PolicySettings": {
    "TimeoutMinutes": 10,
    "AllowedBeforeBreaking": 3,
    "DurationOfBreakInSeconds": 30
  },
  "RequestTimeoutSeconds": 600,
  "AllowedHosts": "*",
  "Gateway": {
    "Resilience": {
      "RetryEnabled": true,
      "MaxRetryAttempts": 0,
      "BaseDelayMs": 200
    }
  },
  "JwtSettings": {
    "AccessTokenSettings": {
      "Issuer": "http://localhost:5000/",
      "Audience": "http://localhost/",
      "PublicKey": ""
    }
  },
  "ReverseProxy": {
    "Routes": {
      "gov-org-check": {
        "ClusterId": "gov-cluster",        
        "Match": {
          "Path": "/Gov/OrganizationCheck",
          "Methods": [ "GET" ]
        }
      },
      "export-excel-check": {
        "ClusterId": "export-excel-cluster",
        "AuthorizationPolicy": "GatewayAuth",
        "Match": {
          "Path": "/ExportExcel/HealthCheck",
          "Methods": [ "GET" ]
        }
      },
      "exchange-rates-get": {
        "ClusterId": "reference-info-cluster",
        "AuthorizationPolicy": "GatewayAuth",
        "Metadata": {
          "CacheEnabled": "true",
          "CacheTtl": "00:05:00"
        },
        "Match": {
          "Path": "/ReferenceInfo/ExchangeRates/GetList",
          "Methods": [ "GET" ]
        }
      },

      ////
      "DebugRoute": {
        "ClusterId": "DebugCluster",
        "Match": {
          "Path": "/debug-api/{**remainder}" // Используем remainder для захвата всего хвоста
        },
        "Metadata": {
          "CacheEnabled": "false",
          "CacheTtl": "00:05:00",
          "RetryEnabled": "true",
          "RetryCount": "5"
        },
        "Transforms": [
          { "PathRemovePrefix": "/debug-api" } // Удаляем /debug-api перед пересылкой
        ]
      },
      ////

      // Весь основной трафик и проверка LIVE идут на основной кластер
      "export-excel-live": {
        "ClusterId": "export-excel-cluster-live",
        "Match": {
          "Path": "/ExcelExport/health/live"
        }
      },
      // Проверка STARTUP идет на отдельный кластер
      "export-excel-startup": {
        "ClusterId": "export-excel-startup-cluster",
        "Match": {
          "Path": "/ExcelExport/health/startup"
        }
      },

      // --- НОВЫЕ маршруты для Swagger ---
      "auth-swagger-ui": {
        "ClusterId": "gov-cluster",
        "Match": {
          "Path": "/Auth/swagger/v1/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v1/Auth" }
        ]
      },
      "auth-v2-swagger-ui": {
        "ClusterId": "gov-cluster",
        "Match": {
          "Path": "/AuthV2/swagger/v2/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v2/AuthV2" }
        ]
      },
      "gov-swagger-ui": {
        "ClusterId": "gov-cluster",
        "Match": {
          "Path": "/Gov/swagger/{**remainder}"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v1/Data" }
        ]
      },
      "broker-swagger-ui": {
        "ClusterId": "gov-cluster",
        "Match": {
          "Path": "/Broker/swagger/v1/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v1/Dashboards" }
        ]
      },
      "send-messages-swagger-ui": {
        "ClusterId": "gov-cluster",
        "Match": {
          "Path": "/Messages/swagger/v1/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v1/SendMessages" }
        ]
      },
      "customer-settings-swagger-ui": {
        "ClusterId": "gov-cluster",
        "Match": {
          "Path": "/CustomerSettings/swagger/v1/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v1/CustomerSettings" }
        ]
      },
      "customer-settings-v2-swagger-ui": {
        "ClusterId": "gov-cluster",
        "Match": {
          "Path": "/CustomerSettingsV2/swagger/v2/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v2/CustomerSettingsV2" }
        ]
      },
      "dashboards-import-swagger-ui": {
        "ClusterId": "gov-cluster",
        "Match": {
          "Path": "/DashboardsImport/swagger/v1/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v1/DashboardsImport" }
        ]
      },
      "referencesapi-swagger-ui": {
        "ClusterId": "gov-cluster",
        "Match": {
          "Path": "/References/swagger/v1/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v1/References" }
        ]
      },
      "logview-swagger-ui": {
        "ClusterId": "gov-cluster",
        "Match": {
          "Path": "/LogView/swagger/v1/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v1/LogView" }
        ]
      },
      "mapping-control-swagger-ui": {
        "ClusterId": "gov-cluster",
        "Match": {
          "Path": "/MappingControl/swagger/v1/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v1/MappingControl" }
        ]
      },
      "calendar-swagger-ui": {
        "ClusterId": "gov-cluster",
        "Match": {
          "Path": "/Calendar/swagger/v1/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v1/CalendarService" }
        ]
      },
      "reference-swagger-ui": {
        "ClusterId": "reference-info-cluster",
        "Match": {
          "Path": "/ReferenceInfo/swagger/v1/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v1/ReferenceInfo" }
        ]
      },
      "calendar-broker-swagger-ui": {
        "ClusterId": "gov-cluster",
        "Match": {
          "Path": "/CalendarBroker/swagger/v1/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v1/CalendarBroker" }
        ]
      },
      "export-swagger-ui": {
        "ClusterId": "export-excel-cluster",
        "Match": {
          "Path": "/ExportExcel/swagger/{**remainder}"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v1/exportexcel" }
        ]
      },
      "ai-chat-handler-swagger-ui": {
        "ClusterId": "gov-cluster",
        "Match": {
          "Path": "/AiChat/swagger/v1/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v1/ai-chat-handler" }
        ]
      },
      "notifications-swagger-ui": {
        "ClusterId": "gov-cluster",
        "Match": {
          "Path": "/Notifications/swagger/v1/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v1/NotificationsService" }
        ]
      },
      "ai-helper-kenes-swagger-ui": {
        "ClusterId": "gov-cluster",
        "Match": {
          "Path": "/AiHelper/swagger/v1/swagger.json"
        },
        "Transforms": [
          { "PathSet": "/swagger/docs/v1/ai-helper-kenes" }
        ]
      }
    },
    "Clusters": {
      "gov-cluster": {
        "HttpRequest": {
          "Timeout": "00:10:00"
        },
        "Destinations": {
          "default": { "Address": "https://dev-swagger.kense.biz" }
        }
      },
      "export-excel-cluster": {
        "Destinations": {
          "default": { "Address": "https://dev-swagger.kense.biz" }
        }
      },
      "reference-info-cluster": {
        "Destinations": {
          "default": { "Address": "https://dev-swagger.kense.biz" }
        }
      },

      /////
      "DebugCluster": {
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7280"
          }
        }
      },
      /////

      "export-excel-cluster-live": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Path": "/ExportExcel/health/live" // Исправлено с ExcelExport
          }
        },
        "Destinations": {
          "default": { "Address": "https://dev-swagger.kense.biz" }
        }
      },
      "export-excel-startup-cluster": {
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Path": "/ExportExcel/health/startup" // Исправлено
          }
        },
        "Destinations": {
          "default": { "Address": "https://dev-swagger.kense.biz" }
        }
      }
    }
  }

}
